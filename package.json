{
  "name": "beuty_consult",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "youtube:sync": "python3 scripts/youtube/extract_transcripts.py && python3 scripts/youtube/fetch_titles.py && python3 scripts/youtube/build_chunks.py",
    "youtube:index": "node scripts/youtube/index_vectors.mjs",
    "youtube:full": "python3 scripts/youtube/fetch_channel_videos.py && npm run youtube:sync && npm run youtube:index",
    "db:leads": "node scripts/apply-leads-migration.mjs",
    "db:migrate": "node scripts/apply-migrations.mjs",
    "youtube:id-hospital": "node scripts/youtube/build-hospital-knowledge.mjs --channel \"https://www.youtube.com/@IDhospital/videos\" --out data/hospitals/id-hospital/videos_knowledge.json --max 12 --name \"아이디병원\"",
    "youtube:da-hospital": "node scripts/youtube/build-hospital-knowledge.mjs --channel \"https://www.youtube.com/@DAPRS/videos\" --out data/hospitals/da-plastic/videos_knowledge.json --max 12 --name \"디에이성형외과\"",
    "youtube:network": "node scripts/youtube/sync-hospital-network.mjs --max 8",
    "youtube:network:all": "node scripts/youtube/sync-hospital-network.mjs --max 10"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@pinecone-database/pinecone": "^7.2.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-compare-slider": "^4.0.0",
    "react-dom": "19.2.4",
    "replicate": "^1.4.0",
    "sharp": "^0.35.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "youtube-transcript": "^1.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
